<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Self Check-In | InkedInLIFTv2</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <style>
    body { background:#f8f9fa; }
    .site-container { max-width:1100px; margin-top:20px; }
  </style>
</head>
<body>

  <main class="site-container container">
    <div class="d-flex align-items-center justify-content-center" style="min-height:70vh;">
      <div class="card shadow" style="width:100%; max-width:420px; padding:1rem;">
        <h3 class="mb-3">Self Check-In</h3>
        <p class="text-muted mb-3">Welcome to InkedInLIFT! Please check in to start your session.</p>
         <form id="selfCheckinForm" novalidate>
           <div class="mb-3">
             <label class="form-label">Email (Optional for walk-ins)</label>
             <input type="email" id="checkinEmail" class="form-control" placeholder="your.email@example.com" />
           </div>
           <div class="mb-3">
             <label class="form-label">Full Name (Provide if no email)</label>
             <input type="text" id="checkinName" class="form-control" placeholder="Your Name" />
           </div>
           <div id="validationErrors" class="alert alert-danger d-none mb-3"></div>
           <button type="submit" class="btn btn-primary w-100">Check In</button>
         </form>
        <div id="message" class="mt-3"></div>
        <hr />
        <div class="text-center">
          <a href="/dashboard" class="btn btn-outline-secondary btn-sm">Back to Dashboard</a>
        </div>
      </div>
    </div>
  </main>

  <script>
    document.getElementById("selfCheckinForm").addEventListener("submit", async (e) => {
      e.preventDefault();
      const email = document.getElementById("checkinEmail").value.trim();
      const name = document.getElementById("checkinName").value.trim();
      const messageEl = document.getElementById("message");
      const validationEl = document.getElementById("validationErrors");
      
      // Clear previous errors
      validationEl.classList.add('d-none');
      messageEl.innerHTML = '';

      // Validate: at least one is required
      if (!email && !name) {
        validationEl.textContent = "Please provide either your email address or full name to check in.";
        validationEl.classList.remove('d-none');
        return;
      }

      try {
        const res = await fetch("/api/checkins", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email, name })
        });

        const data = await res.json();

        if (res.ok) {
          messageEl.textContent = `✓ ${data.message || "Check-in successful!"}`;
          messageEl.className = 'alert alert-success';
          document.getElementById("selfCheckinForm").reset();
        } else {
          messageEl.textContent = `✗ ${data.error || "Check-in failed"}`;
          messageEl.className = 'alert alert-danger';
        }
      } catch (err) {
        messageEl.textContent = `✗ Network error. Please try again.`;
        messageEl.className = 'alert alert-danger';
      }
    });

    // Logout functionality
    document.getElementById("logoutBtn").addEventListener("click", () => {
      localStorage.removeItem("token");
      document.cookie = "token=; path=/; max-age=0";
      window.location.href = "/";
    });
  </script>
</body>
</html>
